# Styles
font-size = 16
font-family = "Fira Code"
macos-titlebar-style = tabs
macos-titlebar-proxy-icon = hidden
palette = 0=#111111
palette = 1=#ff0000
palette = 2=#00ff00
palette = 3=#ffff00
palette = 4=#00aaff
palette = 5=#ff5faf
palette = 6=#00ffcc
palette = 7=#cccccc
palette = 8=#666666
palette = 9=#ff0000
palette = 10=#00ff00
palette = 11=#ffff00
palette = 12=#00aaff
palette = 13=#ff5faf
palette = 14=#00ffcc
palette = 15=#ffffff
background = #050505
foreground = #cccccc
cursor-color = #00ff00
cursor-text = #050505
selection-background = #333333
selection-foreground = #cccccc

# Window
window-padding-x = 12
window-padding-y = 8
window-padding-balance = true
window-height = 50
window-width = 80
window-theme = dark
background-opacity = 0.90
background-blur = macos-glass-regular

# Quick terminal
quick-terminal-position = left
quick-terminal-size = 40%
quick-terminal-screen = mouse
quick-terminal-autohide = false
quick-terminal-space-behavior = remain
quick-terminal-animation-duration = 0
keybind = global:cmd+shift+semicolon=toggle_quick_terminal

# Behavior
confirm-close-surface = false
mouse-hide-while-typing = true
copy-on-select = false
clipboard-trim-trailing-spaces = true
bell-features = border
window-inherit-working-directory = false

# Keyboard
keybind = alt+backspace=text:\x1b\x7f
keybind = shift+enter=text:\n
