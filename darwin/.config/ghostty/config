# Styles
font-size = 16
font-family = "Fira Code"
macos-titlebar-style = tabs
macos-titlebar-proxy-icon = hidden
palette = 0=#2a2a2a
palette = 1=#ff0000
palette = 2=#00ff00
palette = 3=#ffff00
palette = 4=#008ed6
palette = 5=#ff5faf
palette = 6=#00ffcc
palette = 7=#d0d0d0
palette = 8=#858585
palette = 9=#ff0000
palette = 10=#00ff00
palette = 11=#ffff00
palette = 12=#33b5ff
palette = 13=#ff5faf
palette = 14=#00ffcc
palette = 15=#f2f2f2
background = #121212
foreground = #d0d0d0
cursor-color = #00ff00
cursor-text = #121212
selection-background = #2a2a2a
selection-foreground = #f2f2f2

# Window
window-padding-x = 12
window-padding-y = 8
window-padding-balance = true
window-height = 50
window-width = 80
window-theme = dark
background-opacity = 1
background-blur = false

# Quick terminal
quick-terminal-position = left
quick-terminal-size = 40%
quick-terminal-screen = mouse
quick-terminal-autohide = false
quick-terminal-space-behavior = remain
quick-terminal-animation-duration = 0
keybind = global:cmd+shift+semicolon=toggle_quick_terminal

# Behavior
confirm-close-surface = false
mouse-hide-while-typing = true
copy-on-select = false
clipboard-trim-trailing-spaces = true
bell-features = border
window-inherit-working-directory = false

# Keyboard
keybind = alt+backspace=text:\x1b\x7f
keybind = shift+enter=text:\n
