  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#858585"
      }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "storage.modifier", "storage.type", "support.type.property-name.json"],
      "settings": {
        "foreground": "#33b5ff"
      }
    },
    {
      "name": "Functions",
      "scope": ["entity.name.function", "meta.function-call", "support.function", "variable.function"],
      "settings": {
        "foreground": "#ffff00"
      }
    },
    {
      "name": "Identifiers",
      "scope": ["entity.name.variable", "meta.object-literal.key", "support.variable", "variable", "variable.other.property"],
      "settings": {
        "foreground": "#00ffcc"
      }
    },
    {
      "name": "Strings",
      "scope": ["string", "constant.other.symbol"],
      "settings": {
        "foreground": "#00ff00"
      }
    },
    {
      "name": "Numbers and constants",
      "scope": ["constant.language", "constant.numeric", "constant.character", "support.constant"],
      "settings": {
        "foreground": "#00ff00"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.class",
        "entity.name.enum",
        "entity.name.interface",
        "entity.name.struct",
        "entity.name.type",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#00ff00"
      }
    },
    {
      "name": "Operators and punctuation",
      "scope": ["keyword.operator", "punctuation", "meta.brace"],
      "settings": {
        "foreground": "#858585"
      }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#ff0000"
      }
    },
    {
      "name": "YAML keys",
      "scope": ["entity.name.tag.yaml", "meta.map.key.yaml entity.name.tag.yaml", "meta.flow-pair.key.yaml entity.name.tag.yaml"],
      "settings": {
        "foreground": "#33b5ff",
        "fontStyle": "bold"
      }
    },
    {
      "name": "YAML string values",
      "scope": [
        "string.quoted.double.yaml",
        "string.quoted.single.yaml",
        "string.unquoted.block.yaml",
        "string.unquoted.plain.in.yaml",
        "string.unquoted.plain.out.yaml"
      ],
      "settings": {
        "foreground": "#00ff00"
      }
    },
    {
      "name": "YAML numbers",
      "scope": ["constant.numeric.float.yaml", "constant.numeric.integer.yaml"],
      "settings": {
        "foreground": "#ffff00"
      }
    },
    {
      "name": "YAML booleans and null",
      "scope": ["constant.language.boolean.yaml", "constant.language.null.yaml"],
      "settings": {
        "foreground": "#ff5faf"
      }
    },
    {
      "name": "YAML anchors and aliases",
      "scope": [
        "entity.name.type.anchor.yaml",
        "keyword.control.flow.alias.yaml",
        "keyword.control.property.anchor.yaml",
        "variable.other.alias.yaml"
      ],
      "settings": {
        "foreground": "#ff5faf"
      }
    },
    {
      "name": "YAML directives",
      "scope": [
        "keyword.other.directive.tag.yaml",
        "keyword.other.directive.yaml.yaml",
        "string.unquoted.directive-name.yaml",
        "string.unquoted.directive-parameter.yaml"
      ],
      "settings": {
        "foreground": "#ffff00"
      }
    },
    {
      "name": "TOML keys",
      "scope": ["support.type.property-name.toml", "support.type.property-name.array.toml", "support.type.property-name.table.toml"],
      "settings": {
        "foreground": "#33b5ff",
        "fontStyle": "bold"
      }
    },
    {
      "name": "TOML table names",
      "scope": ["meta.table.toml", "meta.array.table.toml", "meta.table.inline.toml"],
      "settings": {
        "foreground": "#33b5ff",
        "fontStyle": "bold"
      }
    },
    {
      "name": "TOML string values",
      "scope": [
        "string.quoted.single.basic.line.toml",
        "string.quoted.single.literal.line.toml",
        "string.quoted.triple.basic.block.toml",
        "string.quoted.triple.literal.block.toml"
      ],
      "settings": {
        "foreground": "#00ff00"
      }
    },
    {
      "name": "TOML numbers",
      "scope": [
        "constant.numeric.bin.toml",
        "constant.numeric.float.toml",
        "constant.numeric.hex.toml",
        "constant.numeric.inf.toml",
        "constant.numeric.integer.toml",
        "constant.numeric.nan.toml",
        "constant.numeric.oct.toml"
      ],
      "settings": {
        "foreground": "#ffff00"
      }
    },
    {
      "name": "TOML booleans",
      "scope": ["constant.language.boolean.toml"],
      "settings": {
        "foreground": "#ff5faf"
      }
    },
    {
      "name": "TOML dates and times",
      "scope": [
        "constant.other.time.date.toml",
        "constant.other.time.datetime.local.toml",
        "constant.other.time.datetime.offset.toml",
        "constant.other.time.time.toml"
      ],
      "settings": {
        "foreground": "#00ffcc"
      }
    },
    {
      "name": "Markup headings",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": {
        "foreground": "#00ff00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup links",
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": {
        "foreground": "#33b5ff"
      }
    },
    {
      "name": "Markup inserted",
      "scope": ["markup.inserted", "markup.changed.git_gutter.inserted"],
      "settings": {
        "foreground": "#00ff00"
      }
    },
    {
      "name": "Markup changed",
      "scope": ["markup.changed", "markup.changed.git_gutter.modified"],
      "settings": {
        "foreground": "#ffff00"
      }
    },
    {
      "name": "Markup deleted",
      "scope": ["markup.deleted", "markup.changed.git_gutter.deleted"],
      "settings": {
        "foreground": "#ff0000"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#00ff00",
    "enum": "#00ff00",
    "enumMember": "#00ff00",
    "function": "#ffff00",
    "interface": "#00ff00",
    "keyword": "#33b5ff",
    "macro": "#ffff00",
    "method": "#ffff00",
    "namespace": "#33b5ff",
    "number": "#00ff00",
    "operator": "#858585",
    "parameter": "#00ffcc",
    "property": "#00ffcc",
    "string": "#00ff00",
    "struct": "#00ff00",
    "type": "#00ff00",
    "typeParameter": "#00ff00",
    "variable": "#00ffcc",
    "variable.readonly": "#00ff00",
    "*.declaration": {
      "bold": true
    },
    "*.deprecated": {
      "strikethrough": true
    }
  }
}
