#!/usr/bin/env bash

set -euo pipefail

readonly DOTBOT_DIR="dotbot"
readonly DOTBOT_BIN="bin/dotbot"
BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly BASEDIR
readonly LOCAL_ENVRC="${HOME}/.envrc"
readonly REPO_ENVRC="${BASEDIR}/base/.envrc"

cd "${BASEDIR}"

# Migrate .envrc from the previous in-repo location to the local home file.
if [ -f "${REPO_ENVRC}" ] && [ ! -L "${REPO_ENVRC}" ]; then
  if [ -L "${LOCAL_ENVRC}" ]; then
    rm "${LOCAL_ENVRC}"
  fi
  mv "${REPO_ENVRC}" "${LOCAL_ENVRC}"
fi

# Keep secrets/local overrides outside the repo while preserving an editable repo path.
if [ ! -f "${LOCAL_ENVRC}" ]; then
  cp "${BASEDIR}/base/example.envrc" "${LOCAL_ENVRC}"
fi

if [ ! -e "${REPO_ENVRC}" ]; then
  ln -s "${LOCAL_ENVRC}" "${REPO_ENVRC}"
fi

# Update dotbot submodules.
git -C "${BASEDIR}/${DOTBOT_DIR}" submodule update --init --recursive

# If not set, install the base group and include x11 when an X server is active.
if [ -z "${DOTFILE_GROUPS:-}" ]; then
  DOTFILE_GROUPS="base"

  if command -v xset >/dev/null 2>&1 && xset q >/dev/null 2>&1; then
    DOTFILE_GROUPS="${DOTFILE_GROUPS},x11"
  fi
fi

printf 'Using groups: %s\n' "${DOTFILE_GROUPS}"

IFS=',' read -r -a dotfile_groups <<< "${DOTFILE_GROUPS}"
for group in "${dotfile_groups[@]}"; do
  group="${group#"${group%%[![:space:]]*}"}"
  group="${group%"${group##*[![:space:]]}"}"
  [ -n "${group}" ] || continue

  config="${group}.yaml"
  if [ ! -f "${BASEDIR}/${config}" ]; then
    printf 'Cannot find %s\n' "${config}" >&2
    exit 1
  fi

  printf 'Configuring %s\n' "${config}"
  "${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASEDIR}" -c "${config}" "$@"
done
