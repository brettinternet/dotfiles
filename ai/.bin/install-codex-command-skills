#!/bin/sh

set -eu

commands_dir=${1:-ai/commands}
skills_dir=${2:-"$HOME/.agents/skills"}
authored_skills_dir=${3:-ai/skills}

marker='<!-- Generated by install-codex-command-skills. -->'
agent_marker='# Generated by install-codex-command-skills.'
for command in "$commands_dir"/*.md; do
  [ -f "$command" ] || continue

  name=$(basename "$command" .md)
  description=$(sed -n 's/^description: //p' "$command" | head -n 1)
  if [ -z "$description" ]; then
    printf 'Missing description in command: %s\n' "$command" >&2
    exit 1
  fi

  authored_skill="$authored_skills_dir/$name/SKILL.md"
  if [ -f "$authored_skill" ]; then
    printf 'Command and authored skill share a name: %s and %s\nUse a distinct authored skill name so both remain available.\n' "$command" "$authored_skill" >&2
    exit 1
  fi

  skill="$skills_dir/$name/SKILL.md"
  if [ -e "$skill" ] && ! grep -Fqx "$marker" "$skill"; then
    printf 'Refusing to overwrite unmanaged Codex skill: %s\n' "$skill" >&2
    exit 1
  fi
done

for command in "$commands_dir"/*.md; do
  [ -f "$command" ] || continue

  name=$(basename "$command" .md)
  description=$(sed -n 's/^description: //p' "$command" | head -n 1)
  skill_dir="$skills_dir/$name"
  skill="$skill_dir/SKILL.md"
  agent="$skill_dir/agents/openai.yaml"
  mkdir -p "$skill_dir/agents"

  {
    printf '%s\n' '---'
    printf 'name: %s\n' "$name"
    printf 'description: %s\n' "$description"
    printf '%s\n' '---'
    printf '%s\n' "$marker"
    # Dollar-prefixed placeholders must remain literal in generated Markdown.
    # shellcheck disable=SC2016
    printf '\nWhen explicitly invoked as `$%s`, treat the text supplied with the invocation as `$ARGUMENTS`. Where the command uses `$1`, `$2`, or `$@`, interpret them as the first, second, or all supplied arguments.\n' "$name"
    awk 'NR == 1 { next } frontmatter && /^---$/ { frontmatter=0; next } frontmatter { next } { print }' frontmatter=1 "$command"
  } > "$skill"

  display_name=$(printf '%s' "$name" | tr '-' ' ')
  {
    printf '%s\n' '# Generated by install-codex-command-skills.' 'interface:'
    printf '  display_name: "%s"\n' "$display_name"
    printf '  short_description: "Run the %s command workflow"\n' "$name"
    printf '  default_prompt: "Use $%s with the relevant arguments to run this command workflow."\n' "$name"
    printf '%s\n' 'policy:' '  allow_implicit_invocation: false'
  } > "$agent"
done

# Reconcile stale adapters only after every current command validates and generates
# successfully. A replaced command adapter requires both generated markers; linked
# or copied authored skills are preserved.
for skill in "$skills_dir"/*/SKILL.md; do
  [ -f "$skill" ] || continue
  [ ! -L "$skill" ] || continue

  skill_dir=$(dirname "$skill")
  name=$(basename "$skill_dir")
  [ ! -f "$commands_dir/$name.md" ] || continue
  grep -Fqx "$marker" "$skill" || continue
  if [ -f "$authored_skills_dir/$name/SKILL.md" ]; then
    grep -Fqx "$agent_marker" "$skill_dir/agents/openai.yaml" || continue
  fi

  [ ! -L "$skill_dir" ] || continue
  rm -rf "$skill_dir"
done
