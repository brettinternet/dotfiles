#!/usr/bin/env python3
"""Same-host fenced work claims and coordination-only leases."""

from __future__ import annotations

import argparse
import contextlib
import datetime as dt
import fcntl
import hashlib
import json
import math
import os
from pathlib import Path
import sqlite3
import subprocess
import tempfile
import time
from typing import Any, Iterator

DEFAULT_TTL = 900.0
MAX_TTL = 3600.0


class ClaimError(Exception):
    def __init__(self, reason: str, *, code: int = 2, **details: Any) -> None:
        super().__init__(reason)
        self.reason = reason
        self.code = code
        self.details = details


def claim_home() -> Path:
    override = os.environ.get("BACKLOG_CLAIM_HOME")
    if override:
        return Path(override).expanduser().resolve()
    state_home = Path(
        os.environ.get("XDG_STATE_HOME", Path.home() / ".local" / "state")
    )
    return (state_home / "backlog-work-claims").resolve()


@contextlib.contextmanager
def database_setup_lock(home: Path) -> Iterator[None]:
    descriptor = os.open(home / "database.lock", os.O_CREAT | os.O_RDWR, 0o600)
    try:
        fcntl.flock(descriptor, fcntl.LOCK_EX)
        yield
    finally:
        os.close(descriptor)


def connect() -> sqlite3.Connection:
    home = claim_home()
    home.mkdir(parents=True, exist_ok=True, mode=0o700)
    connection = sqlite3.connect(
        home / "claims.sqlite3", timeout=30, isolation_level=None
    )
    connection.row_factory = sqlite3.Row
    connection.execute("PRAGMA busy_timeout = 30000")
    with database_setup_lock(home):
        connection.execute("PRAGMA journal_mode = WAL")
        connection.execute("PRAGMA synchronous = FULL")
        connection.executescript(
            """
            CREATE TABLE IF NOT EXISTS epochs (
                claim_id TEXT PRIMARY KEY,
                resource TEXT NOT NULL,
                agent_id TEXT NOT NULL,
                session_id TEXT NOT NULL,
                owner_id TEXT NOT NULL,
                work_key TEXT NOT NULL,
                acquired_at REAL NOT NULL
            );
            CREATE TABLE IF NOT EXISTS resources (
                resource TEXT PRIMARY KEY,
                revision INTEGER NOT NULL
            );
            CREATE TABLE IF NOT EXISTS claims (
                resource TEXT PRIMARY KEY,
                claim_id TEXT NOT NULL,
                token TEXT NOT NULL,
                revision INTEGER NOT NULL,
                agent_id TEXT NOT NULL,
                session_id TEXT NOT NULL,
                owner_id TEXT NOT NULL,
                work_key TEXT NOT NULL,
                acquired_at REAL NOT NULL,
                acquire_ttl REAL NOT NULL,
                coordination_only INTEGER NOT NULL DEFAULT 0,
                heartbeat_at REAL NOT NULL,
                expires_at REAL NOT NULL,
                last_operation_id TEXT,
                last_operation_kind TEXT,
                last_receipt TEXT
            );
            CREATE TABLE IF NOT EXISTS releases (
                resource TEXT NOT NULL,
                claim_id TEXT NOT NULL,
                token TEXT NOT NULL,
                revision INTEGER NOT NULL,
                operation_id TEXT NOT NULL,
                released_at REAL NOT NULL,
                receipt TEXT NOT NULL,
                PRIMARY KEY (resource, claim_id)
            );
            """
        )
        columns = {
            row["name"] for row in connection.execute("PRAGMA table_info(claims)")
        }
        if "acquire_ttl" not in columns:
            connection.execute("ALTER TABLE claims ADD COLUMN acquire_ttl REAL")
        if "coordination_only" not in columns:
            connection.execute(
                "ALTER TABLE claims ADD COLUMN coordination_only "
                "INTEGER NOT NULL DEFAULT 0"
            )
    return connection


def iso8601(value: float) -> str:
    return (
        dt.datetime.fromtimestamp(value, tz=dt.timezone.utc)
        .isoformat()
        .replace("+00:00", "Z")
    )


def row_claim(row: sqlite3.Row, now: float | None = None) -> dict[str, Any]:
    current = time.time() if now is None else now
    return {
        "resource": row["resource"],
        "claimId": row["claim_id"],
        "token": row["token"],
        "revision": row["revision"],
        "agentId": row["agent_id"],
        "sessionId": row["session_id"],
        "ownerId": row["owner_id"],
        "workKey": row["work_key"],
        "guarantee": (
            "local-coordination" if row["coordination_only"] else "fenced"
        ),
        "acquiredAt": iso8601(row["acquired_at"]),
        "acquireTtl": row["acquire_ttl"],
        "heartbeatAt": iso8601(row["heartbeat_at"]),
        "expiresAt": iso8601(row["expires_at"]),
        "expiresAtEpoch": row["expires_at"],
        "active": current < row["expires_at"],
    }


def emit(payload: dict[str, Any]) -> None:
    print(json.dumps(payload, sort_keys=True, separators=(",", ":")))


def emit_text_claims(payload: dict[str, Any]) -> None:
    print("STATE\tRESOURCE\tCLAIM_ID\tOWNER_ID\tEXPIRES_AT")
    for claim in payload["claims"]:
        print(
            "\t".join(
                (
                    "active" if claim["active"] else "expired",
                    claim["resource"],
                    claim["claimId"],
                    claim["ownerId"],
                    claim["expiresAt"],
                )
            )
        )


def resource_lock_path(resource: str) -> Path:
    digest = hashlib.sha256(resource.encode()).hexdigest()
    directory = claim_home() / "locks"
    directory.mkdir(parents=True, exist_ok=True, mode=0o700)
    return directory / f"{digest}.lock"


@contextlib.contextmanager
def resource_lock(resource: str) -> Iterator[None]:
    path = resource_lock_path(resource)
    descriptor = os.open(path, os.O_CREAT | os.O_RDWR, 0o600)
    try:
        try:
            fcntl.flock(descriptor, fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError as error:
            raise ClaimError("resource-guarded", resource=resource) from error
        yield
    finally:
        os.close(descriptor)


@contextlib.contextmanager
def transaction(connection: sqlite3.Connection) -> Iterator[None]:
    connection.execute("BEGIN IMMEDIATE")
    try:
        yield
    except BaseException:
        connection.rollback()
        raise
    else:
        connection.commit()


def require_positive_ttl(value: float) -> float:
    if not math.isfinite(value) or value <= 0 or value > MAX_TTL:
        raise ClaimError(
            "invalid-ttl",
            code=64,
            ttl=value,
            minimumExclusive=0,
            maximumInclusive=MAX_TTL,
        )
    return value


def active_row(connection: sqlite3.Connection, resource: str) -> sqlite3.Row | None:
    return connection.execute(
        "SELECT * FROM claims WHERE resource = ?", (resource,)
    ).fetchone()


def acquire(args: argparse.Namespace) -> dict[str, Any]:
    ttl = require_positive_ttl(args.ttl)
    now = time.time()
    with resource_lock(args.resource), connect() as connection, transaction(connection):
        row = active_row(connection, args.resource)
        identity = (
            args.agent_id,
            args.session_id,
            args.owner_id,
            args.work_key,
            args.coordination_only,
        )
        if row is not None and row["claim_id"] == args.claim_id:
            recorded = (
                row["agent_id"],
                row["session_id"],
                row["owner_id"],
                row["work_key"],
                bool(row["coordination_only"]),
            )
            if recorded != identity:
                raise ClaimError("claim-id-identity-mismatch", resource=args.resource)
            if row["acquire_ttl"] is None or not math.isclose(
                row["acquire_ttl"],
                ttl,
                rel_tol=0,
                abs_tol=1e-6,
            ):
                raise ClaimError(
                    "claim-id-request-mismatch",
                    code=3,
                    resource=args.resource,
                    claimId=args.claim_id,
                )
            if now >= row["expires_at"]:
                raise ClaimError(
                    "claim-expired", resource=args.resource, claim=row_claim(row, now)
                )
            return {
                "ok": True,
                "operation": "acquire",
                "idempotent": True,
                "claim": row_claim(row, now),
            }
        if row is not None and now < row["expires_at"]:
            raise ClaimError(
                "already-claimed", resource=args.resource, claim=row_claim(row, now)
            )
        epoch = connection.execute(
            "SELECT resource, acquired_at FROM epochs WHERE claim_id = ?",
            (args.claim_id,),
        ).fetchone()
        if epoch is not None:
            raise ClaimError(
                "claim-id-reused",
                resource=args.resource,
                originalResource=epoch["resource"],
                originalAcquiredAt=iso8601(epoch["acquired_at"]),
            )
        resource_revision = connection.execute(
            "SELECT revision FROM resources WHERE resource = ?",
            (args.resource,),
        ).fetchone()
        released_revision = connection.execute(
            "SELECT MAX(revision) AS revision FROM releases WHERE resource = ?",
            (args.resource,),
        ).fetchone()
        revision = (
            max(
                row["revision"] if row is not None else 0,
                resource_revision["revision"] if resource_revision is not None else 0,
                released_revision["revision"]
                if released_revision and released_revision["revision"]
                else 0,
            )
            + 1
        )
        token = os.urandom(32).hex()
        values = (
            args.resource,
            args.claim_id,
            token,
            revision,
            args.agent_id,
            args.session_id,
            args.owner_id,
            args.work_key,
            1 if args.coordination_only else 0,
            now,
            ttl,
            now,
            now + ttl,
        )
        connection.execute(
            """
            INSERT INTO epochs (
                claim_id, resource, agent_id, session_id, owner_id, work_key, acquired_at
            ) VALUES (?, ?, ?, ?, ?, ?, ?)
            """,
            (
                args.claim_id,
                args.resource,
                args.agent_id,
                args.session_id,
                args.owner_id,
                args.work_key,
                now,
            ),
        )
        connection.execute(
            """
            INSERT INTO resources (resource, revision) VALUES (?, ?)
            ON CONFLICT(resource) DO UPDATE SET revision = excluded.revision
            """,
            (args.resource, revision),
        )
        connection.execute(
            """
            INSERT INTO claims (
                resource, claim_id, token, revision, agent_id, session_id, owner_id,
                work_key, coordination_only, acquired_at, acquire_ttl, heartbeat_at,
                expires_at, last_operation_id, last_operation_kind, last_receipt
            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, NULL, NULL, NULL)
            ON CONFLICT(resource) DO UPDATE SET
                claim_id=excluded.claim_id, token=excluded.token, revision=excluded.revision,
                agent_id=excluded.agent_id, session_id=excluded.session_id,
                owner_id=excluded.owner_id, work_key=excluded.work_key,
                coordination_only=excluded.coordination_only,
                acquired_at=excluded.acquired_at, heartbeat_at=excluded.heartbeat_at,
                acquire_ttl=excluded.acquire_ttl,
                expires_at=excluded.expires_at, last_operation_id=NULL,
                last_operation_kind=NULL, last_receipt=NULL
            """,
            values,
        )
        created = active_row(connection, args.resource)
        assert created is not None
        return {
            "ok": True,
            "operation": "acquire",
            "idempotent": False,
            "reclaimed": row is not None,
            "claim": row_claim(created, now),
        }


def matching_operation(
    row: sqlite3.Row, operation_id: str, kind: str
) -> dict[str, Any] | None:
    if row["last_operation_id"] != operation_id or row["last_operation_kind"] != kind:
        return None
    if not row["last_receipt"]:
        raise ClaimError("operation-receipt-missing", code=3, operationId=operation_id)
    receipt = json.loads(row["last_receipt"])
    receipt["idempotent"] = True
    receipt["claim"] = row_claim(row)
    return receipt


def require_claim(
    connection: sqlite3.Connection,
    args: argparse.Namespace,
    kind: str,
    *,
    allow_expired_after_lock: bool = False,
) -> tuple[sqlite3.Row, dict[str, Any] | None]:
    row = active_row(connection, args.resource)
    if row is None:
        raise ClaimError("claim-not-found", resource=args.resource)
    if row["claim_id"] != args.claim_id or row["token"] != args.token:
        raise ClaimError("stale-claim", resource=args.resource, claim=row_claim(row))
    cached = matching_operation(row, args.operation_id, kind)
    if cached is not None:
        expected_revision = row["revision"] - 1
        if args.revision != expected_revision:
            raise ClaimError(
                "stale-revision",
                resource=args.resource,
                expectedRevision=expected_revision,
                suppliedRevision=args.revision,
            )
        return row, cached
    if row["revision"] != args.revision:
        raise ClaimError(
            "stale-revision",
            resource=args.resource,
            expectedRevision=row["revision"],
            suppliedRevision=args.revision,
        )
    if not allow_expired_after_lock and time.time() >= row["expires_at"]:
        raise ClaimError("claim-expired", resource=args.resource, claim=row_claim(row))
    return row, None


def update_receipt(
    connection: sqlite3.Connection,
    row: sqlite3.Row,
    args: argparse.Namespace,
    kind: str,
    receipt: dict[str, Any],
) -> sqlite3.Row:
    now = time.time()
    revision = row["revision"] + 1
    ttl = require_positive_ttl(args.ttl)
    cursor = connection.execute(
        """
        UPDATE claims SET revision = ?, heartbeat_at = ?, expires_at = ?,
            last_operation_id = ?, last_operation_kind = ?, last_receipt = ?
        WHERE resource = ? AND claim_id = ? AND token = ? AND revision = ?
        """,
        (
            revision,
            now,
            now + ttl,
            args.operation_id,
            kind,
            json.dumps(receipt, sort_keys=True, separators=(",", ":")),
            row["resource"],
            row["claim_id"],
            row["token"],
            row["revision"],
        ),
    )
    if cursor.rowcount != 1:
        raise ClaimError("claim-update-conflict", code=3, resource=row["resource"])
    connection.execute(
        """
        INSERT INTO resources (resource, revision) VALUES (?, ?)
        ON CONFLICT(resource) DO UPDATE SET revision = excluded.revision
        """,
        (row["resource"], revision),
    )
    updated = active_row(connection, row["resource"])
    assert updated is not None
    return updated


def heartbeat(args: argparse.Namespace) -> dict[str, Any]:
    kind = "heartbeat"
    ttl = require_positive_ttl(args.ttl)
    with resource_lock(args.resource), connect() as connection, transaction(connection):
        row, cached = require_claim(connection, args, kind)
        if cached is not None:
            if cached.get("ttl") != ttl:
                raise ClaimError(
                    "operation-id-request-mismatch",
                    code=3,
                    operationId=args.operation_id,
                )
            return cached
        receipt = {
            "ok": True,
            "operation": kind,
            "operationId": args.operation_id,
            "idempotent": False,
            "ttl": ttl,
        }
        updated = update_receipt(connection, row, args, kind, receipt)
        receipt["claim"] = row_claim(updated)
        return receipt


def release(args: argparse.Namespace) -> dict[str, Any]:
    if not args.reason.strip():
        raise ClaimError("invalid-release-reason", code=64)
    kind = "release"
    with resource_lock(args.resource), connect() as connection, transaction(connection):
        row = active_row(connection, args.resource)
        if row is None:
            prior = connection.execute(
                "SELECT * FROM releases WHERE resource = ? AND claim_id = ?",
                (args.resource, args.claim_id),
            ).fetchone()
            if prior is not None:
                if prior["token"] != args.token:
                    raise ClaimError("stale-claim", resource=args.resource)
                if prior["operation_id"] == args.operation_id:
                    if prior["revision"] != args.revision:
                        raise ClaimError(
                            "stale-revision",
                            resource=args.resource,
                            expectedRevision=prior["revision"],
                            suppliedRevision=args.revision,
                        )
                    if json.loads(prior["receipt"])["reason"] != args.reason:
                        raise ClaimError(
                            "operation-id-request-mismatch",
                            code=3,
                            operationId=args.operation_id,
                        )
                    receipt = json.loads(prior["receipt"])
                    receipt["idempotent"] = True
                    return receipt
            raise ClaimError("claim-not-found", resource=args.resource)
        if row["claim_id"] != args.claim_id or row["token"] != args.token:
            raise ClaimError(
                "stale-claim", resource=args.resource, claim=row_claim(row)
            )
        if row["revision"] != args.revision:
            raise ClaimError(
                "stale-revision",
                resource=args.resource,
                expectedRevision=row["revision"],
                suppliedRevision=args.revision,
            )
        if time.time() >= row["expires_at"]:
            raise ClaimError(
                "claim-expired", resource=args.resource, claim=row_claim(row)
            )
        receipt = {
            "ok": True,
            "operation": kind,
            "operationId": args.operation_id,
            "idempotent": False,
            "releasedClaimId": row["claim_id"],
            "releasedRevision": row["revision"],
            "releasedAt": iso8601(time.time()),
            "reason": args.reason,
        }
        connection.execute(
            """
            INSERT INTO releases (
                resource, claim_id, token, revision, operation_id, released_at, receipt
            ) VALUES (?, ?, ?, ?, ?, ?, ?)
            ON CONFLICT(resource, claim_id) DO UPDATE SET
                token=excluded.token, revision=excluded.revision,
                operation_id=excluded.operation_id, released_at=excluded.released_at,
                receipt=excluded.receipt
            """,
            (
                args.resource,
                args.claim_id,
                args.token,
                args.revision,
                args.operation_id,
                time.time(),
                json.dumps(receipt, sort_keys=True, separators=(",", ":")),
            ),
        )
        connection.execute(
            "DELETE FROM claims WHERE resource = ? AND claim_id = ? AND token = ? AND revision = ?",
            (args.resource, args.claim_id, args.token, args.revision),
        )
        if connection.total_changes < 2:
            raise ClaimError("claim-release-conflict", code=3, resource=args.resource)
        return receipt


def status(args: argparse.Namespace) -> dict[str, Any]:
    with connect() as connection:
        row = active_row(connection, args.resource)
    if row is None:
        return {
            "ok": True,
            "operation": "status",
            "resource": args.resource,
            "state": "free",
        }
    claim = row_claim(row)
    return {
        "ok": True,
        "operation": "status",
        "resource": args.resource,
        "state": "active" if claim["active"] else "expired",
        "claim": claim,
    }


def list_claims(args: argparse.Namespace) -> dict[str, Any]:
    now = time.time()
    with connect() as connection:
        if args.resource is None:
            rows = connection.execute(
                "SELECT * FROM claims ORDER BY resource"
            ).fetchall()
        else:
            rows = connection.execute(
                "SELECT * FROM claims WHERE resource = ? ORDER BY resource",
                (args.resource,),
            ).fetchall()
    claims = []
    for row in rows:
        claim = row_claim(row, now)
        claim.pop("token", None)
        claims.append(claim)
    return {
        "ok": True,
        "operation": "list",
        "claims": claims,
    }


def renew_guard(connection: sqlite3.Connection, row: sqlite3.Row, ttl: float) -> None:
    now = time.time()
    cursor = connection.execute(
        """
        UPDATE claims SET heartbeat_at = ?, expires_at = ?
        WHERE resource = ? AND claim_id = ? AND token = ? AND revision = ?
        """,
        (
            now,
            now + ttl,
            row["resource"],
            row["claim_id"],
            row["token"],
            row["revision"],
        ),
    )
    if cursor.rowcount != 1:
        raise ClaimError("claim-changed-during-guard", code=3, resource=row["resource"])


def require_fenced_claim(row: sqlite3.Row, operation: str) -> None:
    parts = row["resource"].split(":", 2)
    provider = parts[0]
    if provider == "coordination" and len(parts) > 1 and parts[1]:
        provider = parts[1]
    if row["coordination_only"] or parts[0] in {"coordination", "linear"}:
        raise ClaimError(
            f"unsupported-coordination-{operation}",
            provider=provider,
        )


def require_provider_command(row: sqlite3.Row, command: list[str]) -> None:
    require_fenced_claim(row, "exec")
    resource = row["resource"]
    parts = resource.split(":", 2)
    provider = parts[0]
    if provider == "markdown":
        raise ClaimError("unsupported-provider-exec", provider=provider)
    expected = {"backlog-md": "backlog", "github": "gh"}.get(provider)
    if expected is None:
        raise ClaimError("unsupported-resource-provider", provider=provider)
    actual = Path(command[0]).name
    if actual != expected:
        raise ClaimError(
            "provider-command-mismatch",
            code=64,
            provider=provider,
            expectedCommand=expected,
            actualCommand=actual,
        )


def execute(args: argparse.Namespace) -> tuple[dict[str, Any], int]:
    kind = "exec"
    if not args.command:
        raise ClaimError("missing-command", code=64)
    command = args.command[1:] if args.command[0] == "--" else args.command
    if not command:
        raise ClaimError("missing-command", code=64)
    ttl = require_positive_ttl(args.ttl)
    with resource_lock(args.resource), connect() as connection:
        with transaction(connection):
            row, cached = require_claim(connection, args, kind)
            require_provider_command(row, command)
            if cached is not None:
                if cached["command"]["argv"] != command or cached.get("ttl") != ttl:
                    raise ClaimError(
                        "operation-id-request-mismatch",
                        code=3,
                        operationId=args.operation_id,
                    )
                return cached, cached["command"]["returncode"]
            renew_guard(connection, row, ttl)
        try:
            process = subprocess.Popen(
                command, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE
            )
            interval = max(0.01, min(ttl / 3, 5.0))
            while True:
                try:
                    stdout, stderr = process.communicate(timeout=interval)
                    break
                except subprocess.TimeoutExpired:
                    with transaction(connection):
                        current = active_row(connection, args.resource)
                        if (
                            current is None
                            or current["claim_id"] != row["claim_id"]
                            or current["token"] != row["token"]
                            or current["revision"] != row["revision"]
                        ):
                            process.terminate()
                            process.wait()
                            raise ClaimError(
                                "claim-changed-during-guard",
                                code=3,
                                resource=args.resource,
                            )
                        renew_guard(connection, current, ttl)
            command_receipt = {
                "argv": command,
                "returncode": process.returncode,
                "stdout": stdout,
                "stderr": stderr,
            }
        except FileNotFoundError as error:
            command_receipt = {
                "argv": command,
                "returncode": 127,
                "stdout": "",
                "stderr": str(error),
            }
        receipt = {
            "ok": command_receipt["returncode"] == 0,
            "operation": kind,
            "operationId": args.operation_id,
            "idempotent": False,
            "command": command_receipt,
            "ttl": ttl,
        }
        with transaction(connection):
            current = active_row(connection, args.resource)
            if (
                current is None
                or current["claim_id"] != row["claim_id"]
                or current["token"] != row["token"]
                or current["revision"] != row["revision"]
            ):
                raise ClaimError(
                    "claim-changed-during-guard", code=3, resource=args.resource
                )
            updated = update_receipt(connection, current, args, kind, receipt)
            receipt["claim"] = row_claim(updated)
        return receipt, command_receipt["returncode"]


def file_sha256(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as source:
        for chunk in iter(lambda: source.read(1024 * 1024), b""):
            digest.update(chunk)
    return digest.hexdigest()


def atomic_replace(path: Path, content: bytes, mode: int) -> None:
    descriptor, temporary_name = tempfile.mkstemp(
        prefix=".backlog-claim-", dir=path.parent
    )
    temporary = Path(temporary_name)
    try:
        os.fchmod(descriptor, mode)
        with os.fdopen(descriptor, "wb") as target:
            target.write(content)
            target.flush()
            os.fsync(target.fileno())
        os.replace(temporary, path)
        directory = os.open(path.parent, os.O_RDONLY)
        try:
            os.fsync(directory)
        finally:
            os.close(directory)
    finally:
        if temporary.exists():
            temporary.unlink()


def replace_file(args: argparse.Namespace) -> dict[str, Any]:
    if args.resource.split(":", 1)[0] != "markdown":
        raise ClaimError(
            "unsupported-provider-replace-file",
            provider=args.resource.split(":", 1)[0],
        )
    kind = "replace-file"
    target = Path(args.path).expanduser()
    candidate = Path(args.content_file).expanduser()
    if target.is_symlink():
        raise ClaimError("target-is-symlink", code=64, path=str(target))
    target = target.resolve()
    candidate = candidate.resolve()
    expected_resource = local_resource("markdown", target, "")
    if args.resource != expected_resource:
        raise ClaimError(
            "resource-target-mismatch",
            resource=args.resource,
            expectedResource=expected_resource,
            path=str(target),
        )
    if not target.is_file() or not candidate.is_file():
        raise ClaimError(
            "file-not-found", code=64, path=str(target), contentFile=str(candidate)
        )
    content = candidate.read_bytes()
    candidate_hash = hashlib.sha256(content).hexdigest()
    expected_hash = args.expected_sha256.lower()
    ttl = require_positive_ttl(args.ttl)
    with resource_lock(args.resource), connect() as connection:
        with transaction(connection):
            row, cached = require_claim(connection, args, kind)
            require_fenced_claim(row, "replace-file")
            if cached is not None:
                if (
                    cached["path"] != str(target)
                    or cached["previousSha256"] != expected_hash
                    or cached["sha256"] != candidate_hash
                    or cached.get("ttl") != ttl
                ):
                    raise ClaimError(
                        "operation-id-request-mismatch",
                        code=3,
                        operationId=args.operation_id,
                    )
                return cached
        current_hash = file_sha256(target)
        recovered = current_hash == candidate_hash and current_hash != expected_hash
        if current_hash != expected_hash and not recovered:
            raise ClaimError(
                "file-version-conflict",
                code=3,
                path=str(target),
                expectedSha256=expected_hash,
                actualSha256=current_hash,
            )
        if not recovered:
            atomic_replace(target, content, target.stat().st_mode & 0o777)
        receipt = {
            "ok": True,
            "operation": kind,
            "operationId": args.operation_id,
            "idempotent": recovered,
            "path": str(target),
            "previousSha256": expected_hash,
            "sha256": candidate_hash,
            "recovered": recovered,
            "ttl": ttl,
        }
        with transaction(connection):
            current = active_row(connection, args.resource)
            if (
                current is None
                or current["claim_id"] != row["claim_id"]
                or current["token"] != row["token"]
                or current["revision"] != row["revision"]
            ):
                raise ClaimError(
                    "claim-changed-during-guard", code=3, resource=args.resource
                )
            updated = update_receipt(connection, current, args, kind, receipt)
            receipt["claim"] = row_claim(updated)
        return receipt


def git_output(cwd: Path, *arguments: str) -> str | None:
    completed = subprocess.run(
        ["git", "-C", str(cwd), *arguments],
        text=True,
        capture_output=True,
        check=False,
    )
    return completed.stdout.strip() if completed.returncode == 0 else None


def local_resource(provider: str, source_path: Path, item: str) -> str:
    probe = source_path if source_path.is_dir() else source_path.parent
    top_value = git_output(probe, "rev-parse", "--show-toplevel")
    common_value = git_output(probe, "rev-parse", "--git-common-dir")
    if top_value and common_value:
        top = Path(top_value).resolve()
        common = Path(common_value)
        if not common.is_absolute():
            common = (top / common).resolve()
        try:
            locator = source_path.relative_to(top).as_posix()
        except ValueError:
            locator = source_path.as_posix()
        authority = common.as_posix()
    else:
        authority = source_path.as_posix()
        locator = source_path.as_posix()
    target = "__source__" if provider == "markdown" else item
    return f"{provider}:{authority}:{locator}:{target}"


def coordination_resource(provider: str, source: str, item: str) -> str:
    locator = source.strip().rstrip("/")
    target = item.strip()
    if not locator or not target:
        raise ClaimError(
            "invalid-resource-identity",
            code=64,
            provider=provider,
        )
    identity = json.dumps(
        {"provider": provider, "source": locator, "item": target},
        sort_keys=True,
        separators=(",", ":"),
    )
    digest = hashlib.sha256(identity.encode()).hexdigest()
    return f"coordination:{provider}:{digest}"


def resource_key(args: argparse.Namespace) -> dict[str, Any]:
    provider = args.provider.strip().lower()
    if not provider or any(
        not character.isascii()
        or not (character.isalnum() or character == "-")
        for character in provider
    ):
        raise ClaimError("invalid-provider", code=64, provider=args.provider)
    source = args.source.strip()
    item = args.item.strip()
    if not source or not item:
        raise ClaimError(
            "invalid-resource-identity",
            code=64,
            provider=provider,
        )
    if provider == "github":
        source = source.lower().removesuffix(".git")
        resource = f"github:{source}#{item}"
        capability = "item-claim"
        scope = "item"
    elif provider in {"backlog-md", "markdown"}:
        resource = local_resource(
            provider, Path(source).expanduser().resolve(), item
        )
        capability = "source-claim" if provider == "markdown" else "item-claim"
        scope = "source" if provider == "markdown" else "item"
    else:
        resource = coordination_resource(provider, source, item)
        capability = "local-coordination"
        scope = "item"
    if args.coordination_only:
        capability = "local-coordination"
    return {
        "ok": True,
        "operation": "key",
        "provider": provider,
        "capability": capability,
        "scope": scope,
        "fencedMutations": capability != "local-coordination",
        "resource": resource,
    }


def add_claim_arguments(parser: argparse.ArgumentParser, *, ttl: bool = True) -> None:
    parser.add_argument("--resource", required=True)
    parser.add_argument("--claim-id", required=True)
    parser.add_argument("--token", required=True)
    parser.add_argument("--revision", required=True, type=int)
    parser.add_argument("--operation-id", required=True)
    if ttl:
        parser.add_argument("--ttl", type=float, default=DEFAULT_TTL)


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description=__doc__)
    subparsers = parser.add_subparsers(dest="action", required=True)

    key_parser = subparsers.add_parser("key", help="derive one stable resource key")
    key_parser.add_argument("--provider", required=True)
    key_parser.add_argument("--source", required=True)
    key_parser.add_argument("--item", required=True)
    key_parser.add_argument(
        "--coordination-only",
        action="store_true",
        help="derive a lease that coordinates local workers without fencing writes",
    )

    acquire_parser = subparsers.add_parser(
        "acquire", help="atomically acquire or reclaim a lease"
    )
    acquire_parser.add_argument("--resource", required=True)
    acquire_parser.add_argument("--claim-id", required=True)
    acquire_parser.add_argument("--agent-id", required=True)
    acquire_parser.add_argument("--session-id", required=True)
    acquire_parser.add_argument("--owner-id", required=True)
    acquire_parser.add_argument("--work-key", required=True)
    acquire_parser.add_argument(
        "--coordination-only",
        action="store_true",
        help="mark this ownership epoch as unable to fence provider writes",
    )
    acquire_parser.add_argument("--ttl", type=float, default=DEFAULT_TTL)

    status_parser = subparsers.add_parser("status", help="read current lease state")
    status_parser.add_argument("--resource", required=True)

    list_parser = subparsers.add_parser(
        "list", help="list current and expired claims"
    )
    list_parser.add_argument(
        "--resource", help="filter claims to one exact resource"
    )
    list_parser.add_argument(
        "--format",
        choices=("json", "text"),
        default="json",
        help="output format; JSON is the default",
    )


    heartbeat_parser = subparsers.add_parser("heartbeat", help="renew an active lease")
    add_claim_arguments(heartbeat_parser)

    release_parser = subparsers.add_parser("release", help="release an active lease")
    add_claim_arguments(release_parser, ttl=False)
    release_parser.add_argument("--reason", required=True)

    exec_parser = subparsers.add_parser(
        "exec", help="run a provider command under the lease fence"
    )
    add_claim_arguments(exec_parser)
    exec_parser.add_argument("command", nargs=argparse.REMAINDER)

    replace_parser = subparsers.add_parser(
        "replace-file",
        help="atomically replace a Markdown source under the lease fence",
    )
    add_claim_arguments(replace_parser)
    replace_parser.add_argument("--path", required=True)
    replace_parser.add_argument("--expected-sha256", required=True)
    replace_parser.add_argument("--content-file", required=True)

    return parser


def main() -> int:
    args = build_parser().parse_args()
    try:
        if args.action == "key":
            result = resource_key(args)
            code = 0
        elif args.action == "acquire":
            result = acquire(args)
            code = 0
        elif args.action == "status":
            result = status(args)
            code = 0
        elif args.action == "list":
            result = list_claims(args)
            code = 0
        elif args.action == "heartbeat":
            result = heartbeat(args)
            code = 0
        elif args.action == "release":
            result = release(args)
            code = 0
        elif args.action == "exec":
            result, code = execute(args)
        elif args.action == "replace-file":
            result = replace_file(args)
            code = 0
        else:
            raise AssertionError(args.action)
        if args.action == "list" and args.format == "text":
            emit_text_claims(result)
        else:
            emit(result)
        return code
    except ClaimError as error:
        emit({"ok": False, "error": error.reason, **error.details})
        return error.code


if __name__ == "__main__":
    raise SystemExit(main())
