#!/bin/sh

set -eu

source_dir=${1:-ai/claude/agents}
agents_dir=${2:-"$HOME/.codex/agents"}
config=${3:-"$HOME/.codex/config.toml"}
marker='# Generated by install-codex-agents.'
begin='# BEGIN generated Codex agents'
end='# END generated Codex agents'

mkdir -p "$agents_dir" "$(dirname "$config")"
[ -e "$config" ] || : > "$config"

roles=''
for source in "$source_dir"/*.md; do
  [ -f "$source" ] || continue

  name=$(basename "$source" .md)
  description=$(sed -n 's/^description: //p' "$source" | head -n 1)
  case "$name" in
    oracle)
      model='gpt-5.6-sol'
      effort='xhigh'
      ;;
    executor | verifier)
      model='gpt-5.6-luna'
      effort='high'
      ;;
    pr-watcher)
      model='gpt-5.6-luna'
      effort='low'
      ;;
    *)
      printf 'Unsupported Codex agent role: %s\n' "$name" >&2
      exit 1
      ;;
  esac
  if [ -z "$description" ]; then
    printf 'Missing Codex agent metadata in: %s\n' "$source" >&2
    exit 1
  fi
  if grep -q '\"\"\"' "$source"; then
    printf 'Agent body contains unsupported TOML triple quotes: %s\n' "$source" >&2
    exit 1
  fi

  target="$agents_dir/$name.toml"
  if [ -e "$target" ] && ! grep -Fqx "$marker" "$target"; then
    printf 'Refusing to overwrite unmanaged Codex agent: %s\n' "$target" >&2
    exit 1
  fi

  {
    printf '%s\n' "$marker"
    printf 'model = "%s"\n' "$model"
    printf 'model_reasoning_effort = "%s"\n' "$effort"
    printf '%s\n' 'developer_instructions = """'
    awk 'NR == 1 { next } frontmatter && /^---$/ { frontmatter=0; next } frontmatter { next } { print }' frontmatter=1 "$source"
    printf '%s\n' '"""'
  } > "$target"

  escaped_description=$(printf '%s' "$description" | sed 's/\\/\\\\/g; s/"/\\"/g')
  escaped_target=$(printf '%s' "$target" | sed 's/\\/\\\\/g; s/"/\\"/g')
  roles="$roles
[agents.$name]
description = \"$escaped_description\"
config_file = \"$escaped_target\""
done

tmp=$(mktemp "$config.tmp.XXXXXX")
awk -v begin="$begin" -v end="$end" '
  function flush_blanks() {
    while (blanks > 0) {
      print ""
      blanks--
    }
  }
  $0 == begin { blanks=0; skipping=1; next }
  $0 == end { skipping=0; next }
  skipping { next }
  $0 == "" { blanks++; next }
  { flush_blanks(); print }
' "$config" > "$tmp"
{
  printf '\n%s\n' "$begin"
  printf '%s\n' "$roles"
  printf '%s\n' "$end"
} >> "$tmp"
mv "$tmp" "$config"
