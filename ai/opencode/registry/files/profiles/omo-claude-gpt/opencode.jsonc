{
  "$schema": "https://opencode.ai/config.json",
  "disabled_providers": ["opencode"],
  "plugin": ["oh-my-openagent@4.1.0"],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["bunx", "chrome-devtools-mcp@0.26.0"],
    },
  },
}
