{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "atlas": {
      "model": "anthropic/claude-sonnet-4-6",
    },
    "explore": {
      "model": "anthropic/claude-haiku-4-5",
    },
    "metis": {
      "fallback_models": [
        {
          "model": "anthropic/claude-opus-4-7",
          "variant": "max",
        },
      ],
      "model": "anthropic/claude-sonnet-4-6",
    },
    "momus": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max",
    },
    "multimodal-looker": {
      "model": "anthropic/claude-sonnet-4-6",
    },
    "oracle": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max",
    },
    "prometheus": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max",
    },
    "sisyphus": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max",
    },
    "sisyphus-junior": {
      "model": "anthropic/claude-sonnet-4-6",
    },
  },
  "categories": {
    "artistry": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max",
    },
    "deep": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max",
    },
    "quick": {
      "model": "anthropic/claude-haiku-4-5",
    },
    "ultrabrain": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max",
    },
    "unspecified-high": {
      "model": "anthropic/claude-sonnet-4-6",
    },
    "unspecified-low": {
      "model": "anthropic/claude-sonnet-4-6",
    },
    "visual-engineering": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max",
    },
    "writing": {
      "model": "anthropic/claude-sonnet-4-6",
    },
  },
  "background_task": {
    "providerConcurrency": {
      "anthropic": 3,
    },
    "modelConcurrency": {
      "anthropic/claude-opus-4-7": 2,
    },
  },
  "experimental": {
    "aggressive_truncation": true,
    "task_system": true,
  },
}
