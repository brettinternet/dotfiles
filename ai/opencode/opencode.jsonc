{
  "$schema": "https://opencode.ai/config.json",
  "disabled_providers": ["opencode"],
  "plugin": [""],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["bunx", "chrome-devtools-mcp@latest"],
    },
  },
  "agent": {
    // https://models.dev/
    "plan": {
      "description": "System designer and architect.",
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "permission": {
        "edit": "deny",
        "bash": "ask",
        "task": {
          "*": "deny",
          "implementer": "allow",
          "reviewer": "allow",
        },
      },
    },
    "implementer": {
      "description": "Implements one explicit plan task using TDD.",
      "mode": "subagent",
      "model": "openai/gpt-5.3-codex-spark",
      "permission": {
        "edit": "allow",
        "bash": "ask",
      },
    },
    "reviewer": {
      "description": "Reviews completed implementation against the plan, tests, and code quality.",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "permission": {
        "edit": "deny",
        "bash": "ask",
      },
    },
  },
}
